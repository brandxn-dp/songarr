# Soulseek / slskd
SLSKD_URL=http://localhost:5030
SLSKD_API_KEY=your_slskd_api_key_here

# Music paths
MUSIC_LIBRARY_PATH=/home/user/Music/Songarr
DOWNLOAD_PATH=/home/user/Music/Songarr/downloads

# Database
DATABASE_URL=sqlite+aiosqlite:///./songarr.db

# Optional: set via Settings UI instead
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
ACOUSTID_API_KEY=
